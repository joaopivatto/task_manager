# Copy to /etc/taskflow.env and adjust values for your machine.
# Restrict file permissions after creation: sudo chmod 600 /etc/taskflow.env

DB_URL=jdbc:mysql://localhost:3306/taskdb
DB_USER=root
DB_PASSWORD=change_me
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
JAVA_OPTS=-Xms256m -Xmx512m
HEALTHCHECK_URL=http://127.0.0.1:8080/board

